# 🌍 Soil Mineralogy AI — Configurações de Ambiente (Modelo)
# =============================================================
# Renomeie ou copie este arquivo para .env na raiz do projeto:
# cp env.example .env
#
# E configure a sua chave de API do Gemini abaixo:

# Chave de API do Google Gemini (Obrigatória para o funcionamento da IA e RAG de Voz)
GOOGLE_API_KEY=sua_chave_de_api_do_gemini_aqui

# Token opcional do HuggingFace para carregamento de modelos locais (se necessário)
HF_TOKEN=opcional_token_do_huggingface_aqui
